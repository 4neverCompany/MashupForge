# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# LEONARDO_API_KEY: Required for Leonardo.AI image generation.
LEONARDO_API_KEY="MY_LEONARDO_API_KEY"

# Shared secret used by the Sunday-recap cron + instagram-refresh route.
# Generate with: openssl rand -hex 32
CRON_SHARED_SECRET="<32-byte-hex-string>"

# ── Instagram Graph API ───────────────────────────────────────────────────
# Fallback for the body-first credential resolver — when the browser
# settings don't carry an Instagram credential, /api/social/post and
# /api/social/best-times fall back to these env vars. Long-lived Facebook
# Page Token (must start with EAA — IGAA/IGQ Basic Display tokens are
# rejected at app/api/social/post/route.ts).
# Generate via: https://developers.facebook.com/tools/explorer
INSTAGRAM_ACCESS_TOKEN="EAA<your-long-lived-page-token>"

# Instagram business account ID (numeric). Find via Graph API Explorer:
#   GET /me/accounts → page id → GET /<page-id>?fields=instagram_business_account
INSTAGRAM_ACCOUNT_ID="<numeric-ig-business-account-id>"

# ── LLM-INTEGRATION-0513: vercel-ai SDK provider ──────────────────────────
# Set ONE of the following to make /api/ai/prompt resolve a provider.
# Resolution order (first wins): MiniMax → OpenAI → Anthropic → OpenRouter.
# Default models per provider can be overridden globally via
# VERCEL_AI_MODEL or per-call via the request body `model` field.

# MiniMax (default for the vercel-ai backend). Same key shape as the
# nca subprocess path; safe to share with NCA / MMX.
MINIMAX_API_KEY="<your-minimax-key>"

# MiniMax REST base URL. The vercel-ai provider chain reads this to
# target MiniMax's OpenAI-compatible endpoint. Default is the public
# International endpoint; override for region-specific deployments.
MINIMAX_API_BASE_URL="https://api.minimaxi.chat/v1"

# OpenAI — fallback if MiniMax is unset. Default model: gpt-4o-mini.
# OPENAI_API_KEY="sk-..."

# Anthropic — fallback if MiniMax + OpenAI are unset. Default: claude-3-haiku-20240307.
# ANTHROPIC_API_KEY="sk-ant-..."

# OpenRouter — fallback of last resort. Default: openai/gpt-4o-mini.
# OPENROUTER_API_KEY="sk-or-..."

# Optional global model override (skip per-provider defaults).
# VERCEL_AI_MODEL="MiniMax-M2.7"
