# install dirs. See docs/bmad/reviews/spike-vercel-labs-tools.md.
.agents/
skills-lock.json

# Stray repo-local `~/.hermes/` leak — fleet scripts occasionally create
# `.hermes/...` as a relative path when $HOME expansion drops out. Not part
# of the project; the canonical fleet state lives in ~/.hermes/.
.hermes/
