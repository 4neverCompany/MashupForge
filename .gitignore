node_modules/
.next/
# next-env.d.ts is regenerated by `next dev`/`next build` (per Next.js docs:
# "This file should not be edited"). Tracking it causes spurious dirty
# state when devs switch between dev and build modes.
next-env.d.ts
coverage/
.DS_Store
*.log
.env*
!.env.example
.vercel
.pi-install/
tsconfig.tsbuildinfo

# Tauri desktop build output + generated resources
.cache/
src-tauri/target/
src-tauri/gen/schemas/
src-tauri/resources/node/
src-tauri/resources/app/
src-tauri/resources/pi/
src-tauri/resources/nca/
dist/

# git worktree dirs created inside the project root (we use
# I:\c4n-worktrees\<branch>\ as the convention, but the empty stub
# can get re-created by tooling that defaults to a subdir of the
# repo root)
.worktrees/

# Claude Code session files (everything except project-scoped rules,
# which we DO want tracked so every clone / agent sees the same
# guidance — e.g. .claude/rules/release-flow.md).
.claude/*
!.claude/rules/

# Hermes Agent source (cloned for reference)
hermes-agent/
.env*.local

# Per-project agent/skills tooling scratch (regenerable from skills-lock.json,
# symlinks don't survive Windows checkout, NCA caches its own session state).
.agents/
.hermes/
.nca/
.mavis/
skills-lock.json

# pnpm artifacts — MashupForge is a bun project (bun.lock is the only
# lockfile). A stray `pnpm install` leaves these behind AND creates a
# node_modules/.pnpm store that skips native builds (the cause of the
# local better-sqlite3 binding failures). Keep them out of the repo.
pnpm-lock.yaml
pnpm-workspace.yaml

# M3.3-P1 (2026-06-12): marketing / landing-page artifacts that don't
# belong in a desktop-app repo. The PNGs are staging assets for an
# external landing page; the bmad docs are an unused BMAD-method
# installation. The full content is preserved at
# I:\MashupForge-handoff\backup\m33-pre-cleanup-2026-06-12\.
docs/working-folder/
docs/bmad/

# Higgsfield CLI staged for installer bundling by
# scripts/install-higgsfield-cli.ps1 -Dest src-tauri/resources/higgsfield-cli
# (a fetched node_modules artifact, like resources/node and resources/camofox).
src-tauri/resources/higgsfield-cli/
