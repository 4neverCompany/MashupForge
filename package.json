{
  "name": "mashupforge",
  "version": "1.8.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build && node scripts/check-bundle-size.mjs",
    "start": "next start",
    "lint": "eslint .",
    "test": "vitest run",
    "test:watch": "vitest",
    "precommit": "tsc --noEmit && vitest run",
    "typecheck": "tsc --noEmit",
    "test:ci": "vitest run --reporter=verbose",
    "prepare": "simple-git-hooks",
    "clean": "next clean",
    "tauri": "tauri",
    "tauri:dev": "tauri dev",
    "tauri:build": "tauri build"
  },
  "simple-git-hooks": {
    "pre-commit": "bash .githooks/pre-commit && npm run precommit",
    "post-commit": "bash scripts/event-hooks/post-commit.sh",
    "post-merge": "bash scripts/event-hooks/post-merge.sh",
    "pre-push": "bash .githooks/pre-commit && bash scripts/event-hooks/pre-push.sh"
  },
  "dependencies": {
    "@ai-sdk/openai": "^3.0.68",
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@mariozechner/pi-coding-agent": "^0.73.1",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@tauri-apps/plugin-autostart": "^2.5.1",
    "@tauri-apps/plugin-deep-link": "^2.4.9",
    "@tauri-apps/plugin-dialog": "^2",
    "@tauri-apps/plugin-fs": "^2.5.1",
    "@tauri-apps/plugin-opener": "^2.5.4",
    "@tauri-apps/plugin-process": "^2",
    "@tauri-apps/plugin-sql": "^2.0.0",
    "@tauri-apps/plugin-store": "^2",
    "@tauri-apps/plugin-updater": "2.10.1",
    "@vercel/analytics": "^2.0.1",
    "ai": "^6.0.197",
    "autoprefixer": "^10.5.0",
    "idb": "^8.0.0",
    "idb-keyval": "^6.2.4",
    "lucide-react": "^1.16.0",
    "motion": "^12.40.0",
    "next": "^16.2.6",
    "postcss": "^8.5.15",
    "react": "19.2.6",
    "react-dom": "19.2.6",
    "react-markdown": "^10.1.0",
    "sharp": "^0.34.5",
    "twitter-api-v2": "^1.29.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.3.0",
    "@tailwindcss/typography": "^0.5.19",
    "@tauri-apps/api": "^2.11.0",
    "@tauri-apps/cli": "^2.11.2",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/better-sqlite3": "^7.6.10",
    "@types/node": "^25.9.1",
    "@types/react": "^19.2.15",
    "@types/react-dom": "^19",
    "better-sqlite3": "^12.10.0",
    "eslint": "^9.39.4",
    "eslint-config-next": "^16.2.6",
    "fake-indexeddb": "^6.0.0",
    "happy-dom": "^20.9.0",
    "jsdom": "^29.1.1",
    "simple-git-hooks": "^2.13.1",
    "tailwindcss": "4.3.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.7"
  }
}
